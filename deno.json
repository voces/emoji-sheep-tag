{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --watch --env-file server/index.ts --dev",
    "test": "FLY_API_TOKEN= STATUS_KV_DISABLED=1 deno test --no-check --allow-env --allow-net --allow-read --allow-write --unstable-broadcast-channel",
    "test:fast": "deno task test --parallel --reporter=dot",
    "build": "deno run --allow-env --allow-read --allow-write --allow-run scripts/build.ts",
    "shard": "PRIMARY_SERVER=ws://localhost:8000 SHARD_PORT=8001 deno run -A --watch server/shard.ts",
    "shard:compile": "deno compile -A --output dist/shard server/shard.ts",
    "setup-hooks": "mkdir -p .hooks && cp .git/hooks/* .hooks/ 2>/dev/null || true && rm -f .hooks/*.sample 2>/dev/null || true && git config core.hooksPath .hooks",
    "pre-commit": "deno fmt && deno lint && deno check",
    "deploy": "bash scripts/deploy.sh",
    "setup:tauri": "bash scripts/setup-tauri.sh",
    "icons:tauri": "bash -c 'sed \"s/fill=\\\"#6c6863\\\"/fill=\\\"#ff0303\\\"/g; s/fill=\\\"#3b332e\\\"/fill=\\\"#990202\\\"/g\" client/assets/bite.svg > /tmp/bite-icon.svg && magick -background none /tmp/bite-icon.svg -resize 512x512 -gravity center -extent 512x512 PNG32:src-tauri/icons/icon.png && magick src-tauri/icons/icon.png -define icon:auto-resize=256,128,64,48,32,16 src-tauri/icons/icon.ico && rm /tmp/bite-icon.svg && echo \"Generated src-tauri/icons/icon.png and icon.ico\"'",
    "build:tauri": "PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig cargo tauri build",
    "sync:windows": "deno run -A scripts/sync-windows.ts"
  },
  "imports": {
    "@/client-testing/": "./client/testing/",
    "@/components/": "./client/ui/components/",
    "@/hooks/": "./client/ui/hooks/",
    "@/server-testing/": "./server/testing/",
    "@/shared/": "./shared/",
    "@/util/": "./client/ui/util/",
    "@/vars/": "./client/ui/vars/",
    "@std": "jsr:@std",
    "@tauri-apps/api": "npm:@tauri-apps/api",
    "@testing-library/react": "npm:@testing-library/react",
    "@testing-library/user-event": "npm:@testing-library/user-event",
    "@verit/ecs": "jsr:@verit/ecs",
    "@block65/webcrypto-web-push": "npm:@block65/webcrypto-web-push@1.0.2",
    "esbuild": "npm:esbuild",
    "i18next": "npm:i18next",
    "global-jsdom/register": "npm:global-jsdom/register",
    "jsdom": "npm:jsdom",
    "lucide-react": "npm:lucide-react",
    "react-dom": "npm:react-dom",
    "react-i18next": "npm:react-i18next",
    "react": "npm:react",
    "styled-components": "npm:styled-components",
    "three": "npm:three",
    "three/BufferGeometryUtils": "npm:three/examples/jsm/utils/BufferGeometryUtils.js",
    "three/SVGLoader": "npm:three/examples/jsm/loaders/SVGLoader.js",
    "typed-event-target": "https://deno.land/x/typescript_event_target@v1.0.5/mod.ts",
    "zod": "npm:zod"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "dom",
      "dom.asynciterable",
      "webworker"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "npm:react",
    "types": [
      "npm:@types/react",
      "npm:@types/three",
      "./client/assets/asset.d.ts",
      "./client/types.d.ts"
    ]
  },
  "exclude": ["src-tauri/"],
  "fmt": {
    "indentWidth": 2,
    "exclude": ["**/snapshots"]
  },
  "unstable": ["raw-imports", "kv"]
}
